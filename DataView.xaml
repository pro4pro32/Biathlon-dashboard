<Window x:Class="DataBindingDemo.Views.DataView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data View" Height="300" Width="400">
    <Grid>
        <StackPanel>
            <TextBlock Text="Data Binding Example" FontSize="20" FontWeight="Bold" Margin="10"/>
            <TextBox Text="{Binding SomeProperty}" Margin="10"/>
            <Button Content="Submit" Command="{Binding SubmitCommand}" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>